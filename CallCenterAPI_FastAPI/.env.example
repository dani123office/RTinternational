# Database configuration
# Replace with your actual PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/callcenter

# Optional: Alternative database URL format
# POSTGRES_URL=postgresql://user:password@localhost:5432/callcenter

# AI/ML API keys
# Get your key from https://cohere.com
COHERE_API_KEY=your_cohere_api_key_here

# Server configuration
RT_PORT=7219

# CORS origins (comma-separated)
# RT_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Environment indicator
# Set automatically by Vercel, not needed locally
# VERCEL=false
